PORT=3000
NODE_ENV=development
POSTGRES_USER=chargeops
POSTGRES_PASSWORD=chargeops
POSTGRES_DB=chargeops
POSTGRES_PORT=5432
DATABASE_URL=postgresql://chargeops:chargeops@localhost:5432/chargeops
# Minimum 32 characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-secure-random-string-of-at-least-32-chars
# Access token TTL in seconds. Default: 900 (15 minutes)
JWT_ACCESS_TTL_SECONDS=900
# Refresh token TTL in seconds. Default: 2592000 (30 days)
JWT_REFRESH_TTL_SECONDS=2592000
# Include refresh token in JSON response body (fallback for non-browser clients). Default: false
REFRESH_TOKEN_IN_BODY=false